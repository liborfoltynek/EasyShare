<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:EasyShare.Android"
       x:Class="EasyShare.Android.AppShell"
       Shell.FlyoutBehavior="Disabled"
       Shell.BackgroundColor="{StaticResource BackgroundDark}"
       Shell.TitleColor="{StaticResource TextWhite}">
    <ShellContent
        Title="EasyShare"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
</Shell>
