<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EasyShare.Android.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="BackgroundDark">#0f0f14</Color>
            <Color x:Key="SurfaceDark">#1a1a24</Color>
            <Color x:Key="SurfaceBorder">#2a2a3a</Color>
            <Color x:Key="AccentBlue">#6ea8fe</Color>
            <Color x:Key="AccentBlueHover">#8cbbff</Color>
            <Color x:Key="TextPrimary">#e0e0e6</Color>
            <Color x:Key="TextSecondary">#888888</Color>
            <Color x:Key="TextWhite">#ffffff</Color>
            <Color x:Key="WarningYellow">#f0ad4e</Color>
            <Color x:Key="SuccessGreen">#4caf50</Color>
            <Color x:Key="ErrorRed">#ef5350</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
